[
 {
  "res": "text",
  "num": 296,
  "idx": 31,
  "text": "DanceDanceDanceDance!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3394-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 32,
  "text": "Hee, Hee!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3395-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 33,
  "text": "That's a dance?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3396-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 34,
  "text": "What can you expect from a human?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3397-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 35,
  "text": "Well, I think it's cute.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3398-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 36,
  "text": "You think anything is cute!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3399-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 37,
  "text": "Ha, ha, ha!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3400-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 38,
  "text": "Ooooh!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3401-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 39,
  "text": "It does know how to dance.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3402-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 40,
  "text": "Wowie!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3403-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 41,
  "text": "This is neat!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3404-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 42,
  "text": "Gee, I didn't think it could do this.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3405-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 43,
  "text": "Well, I just love it!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3406-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 44,
  "text": "You love an Antwerp!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3407-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 45,
  "text": "Do not!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3408-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 46,
  "text": "Do too!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3409-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 47,
  "text": "So what do you want?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3410-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 48,
  "text": "Why are you here?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3411-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 49,
  "text": "Do you suppose it's hungry?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3412-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 50,
  "text": "What do humans eat?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3413-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 51,
  "text": "Fairies!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3414-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 52,
  "text": "Fairies?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3415-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 53,
  "text": "Everyone knows humans eat animals.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3416-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 54,
  "text": "Yuckie!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3417-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 55,
  "text": "What are you bothering us for?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3418-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 56,
  "text": "Why don't humans ever answer?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3419-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 57,
  "text": "What is this all about?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3420-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 58,
  "text": "What do you want from us?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3421-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 59,
  "text": "He came into our circle!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3422-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 60,
  "text": "Who invited you here?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3423-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 61,
  "text": "How rude!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3424-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 62,
  "text": "You can't come in here!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3425-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 63,
  "text": "Now you're really going to get it!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3426-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 64,
  "text": "What an insult!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3427-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 65,
  "text": "You'll just have to dance!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3428-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 66,
  "text": "Have to dance!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3429-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 67,
  "text": "Dance!  Dance!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3430-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 68,
  "text": "Dance!!  Dance!!  Dance!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3431-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 69,
  "text": "Nyaah, nyaah!  You missed me!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3432-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 70,
  "text": "It wants to play!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3433-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 71,
  "text": "Can't get me!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3434-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 72,
  "text": "Naughty, naughty, naughty.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3435-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 73,
  "text": "Attercop, Attercop!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3436-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 74,
  "text": "Missed me, missed me...",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3437-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 75,
  "text": "...now you've got to kiss me!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3438-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 76,
  "text": "Oooh!  Scary magic!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3439-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 77,
  "text": "You'll never catch me.  Ha, ha!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3440-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 78,
  "text": "Fairy dust is very magical.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3441-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 79,
  "text": "Is that why you're here?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3442-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 80,
  "text": "Why should we give it any dust?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3443-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 81,
  "text": "It danced for us, didn't it?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3444-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 82,
  "text": "Well, I say we give it some dust.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3445-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 83,
  "text": "That's because you have a crush on it.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3446-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 84,
  "text": "Do not!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3447-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 85,
  "text": "Dewdrop's in love with a human.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3448-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 86,
  "text": "Am not!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3449-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 87,
  "text": "Are too!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3450-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 88,
  "text": "If you love it, YOU give it some dust.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3451-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 89,
  "text": "Ick!  Not me...you!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3452-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 90,
  "text": "You!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3453-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 91,
  "text": "No, You!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3454-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 92,
  "text": "No way!  You!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3455-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 93,
  "text": "Not me!  You!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3456-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 94,
  "text": "Make Mikey do it.  She'll touch anything!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3457-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 95,
  "text": "Mikey!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3458-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 96,
  "text": "All right, all right, but you all owe me!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3459-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 97,
  "text": "All right, human.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3460-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 98,
  "text": "Hold out your hand and close your eyes.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3461-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 99,
  "text": "You will get a big surprise!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3462-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 100,
  "text": "No peeking!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3463-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 101,
  "text": "I think it's cheating!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3464-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 102,
  "text": "Oh, just give it some dust!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3465-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 103,
  "text": "You needed a bath, anyway.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3466-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 104,
  "text": "Our mushrooms are special!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3467-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 105,
  "text": "Yeah.  They're magical!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3468-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 106,
  "text": "That's why we dance in rings of mushrooms.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3469-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 107,
  "text": "You better not come into our ring!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3470-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 108,
  "text": "We never let humans into our ring.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3471-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 109,
  "text": "It takes forever to get the smell out!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3472-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 110,
  "text": "It spoils the magic when a human comes in.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3473-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 111,
  "text": "It makes us very, very angry!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3474-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 112,
  "text": "We love our mushrooms!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3475-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 113,
  "text": "We are magic!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3476-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 114,
  "text": "We make rainbows!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3477-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 115,
  "text": "We dance to make the flowers grow.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3478-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 116,
  "text": "We sing to make the colors.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3479-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 117,
  "text": "We're the prettiest things in the world!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3480-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 118,
  "text": "We just want to have fun!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3481-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 119,
  "text": "Fairies live in forests.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3482-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 120,
  "text": "Fairies are GREAT!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3483-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 121,
  "text": "This is our home.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3484-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 122,
  "text": "Woods are wonderful!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3485-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 123,
  "text": "We love trees!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3486-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 124,
  "text": "We love flowers!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3487-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 125,
  "text": "We rule the whole forest!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3488-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 126,
  "text": "Don't tell the Dryad that!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3489-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 127,
  "text": "We make the trees grow!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3490-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 128,
  "text": "She protects the forest and everything.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3491-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 129,
  "text": "She even protects us!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3492-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 130,
  "text": "You'd better not make her mad!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3493-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 131,
  "text": "She'll zap you.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3494-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 132,
  "text": "Her tree is nearby.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3495-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 133,
  "text": "The Dryad is a tree nymph.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3496-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 134,
  "text": "She's very magical.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3497-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 135,
  "text": "This is boring!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3498-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 136,
  "text": "Is that all you care about?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3499-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 137,
  "text": "Shall we dance again?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3500-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 138,
  "text": "What about the human?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3501-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 139,
  "text": "Maybe if we ignore it, it'll go away!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3502-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 140,
  "text": "Let's dance!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3503-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 141,
  "text": "How rude!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3504-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 142,
  "text": "Why, I never!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3505-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 143,
  "text": "Nobody tries that with us!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3506-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 144,
  "text": "Now you're really going to get it!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3507-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 145,
  "text": "What an insult!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3508-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 146,
  "text": "You'll just have to dance!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3509-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 147,
  "text": "Have to dance!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3510-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 148,
  "text": "Dance for us!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3511-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 149,
  "text": "Dance now!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3512-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 150,
  "text": "Dance!!!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3513-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 151,
  "text": "Oh, it's you again!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3514-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 152,
  "text": "Can you dance better now?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3515-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 153,
  "text": "We love to watch you dance.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3516-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 154,
  "text": "You'd better play nice!",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3517-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 155,
  "text": "Did you meet the Dryad?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3518-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 156,
  "text": "We'd love to see you dance.",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3519-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 157,
  "text": "Will you dance for us??",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3520-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 158,
  "text": "Will you dance?",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3521-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 159,
  "text": "Dance?  Dance??",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3522-fairy.mp3"
 },
 {
  "res": "text",
  "num": 296,
  "idx": 160,
  "text": "Dance???",
  "speaker": "fairy",
  "voiceId": 527,
  "file": "qfg1-3523-fairy.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 0,
  "text": "This place seems sinister at night. You see a strangely glowing object at the far end of the alley.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3524-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 3,
  "text": "These two men may be smiling at you, but they don't seem very friendly.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3525-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 6,
  "text": "The dagger looks sharp and very deadly.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3526-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 7,
  "text": "It's a glowing golden coin.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3527-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 8,
  "text": "You just see a glint from here.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3528-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 9,
  "text": "He may be short, but the dagger makes him look 7 feet tall.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3529-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 10,
  "text": "The florid face tells you that this thief is a regular at the \"Aces and Eights\" tavern.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3530-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 11,
  "text": "The whole place is in need of repair.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3531-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 12,
  "text": "Looks like this barrel once contained Dragon's Breath.  The bottom's eaten out.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3532-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 13,
  "text": "A whiff of Troll's Sweat indicates that this barrel is from the \"Aces and Eights\" tavern.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3533-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 15,
  "text": "You're too far away from the back wall.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3534-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 16,
  "text": "\"Aw, now look what ya done.  You made poor Slink run out of patience.\"",
  "speaker": "slink",
  "voiceId": 517,
  "file": "qfg1-3535-slink.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 17,
  "text": "\"Aw, ya forgot to pay.  What a shame.\"",
  "speaker": "slink",
  "voiceId": 517,
  "file": "qfg1-3536-slink.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 18,
  "text": "That's a pretty tall wall.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3537-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 19,
  "text": "The thieves seem to be ignoring you.",
  "speaker": "narrator",
  "voiceId": 545,
  "file": "qfg1-3538-narrator.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 20,
  "text": "\"Yeah, yeah, we know, you're in the Guild too.  How's a poor independent businessman supposed to make a living around here with all this competition?\"",
  "speaker": "slink",
  "voiceId": 517,
  "file": "qfg1-3539-slink.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 21,
  "text": "\"Now go before I forget you made the sign and I make you pay anyway.\"",
  "speaker": "slink",
  "voiceId": 517,
  "file": "qfg1-3540-slink.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 22,
  "text": "\"What's that supposed to be?  You trying to pretend you're a thief or something?  Har, har.\"",
  "speaker": "slink",
  "voiceId": 517,
  "file": "qfg1-3541-slink.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 23,
  "text": "\"You mean to say that the first customer we've had in months is a fellow thief?  And here I thought we were going to make some money.\"",
  "speaker": "slink",
  "voiceId": 517,
  "file": "qfg1-3542-slink.mp3"
 },
 {
  "res": "text",
  "num": 334,
  "idx": 24,
  "text": "\"You had better check in at the Thieves' Guild before you get in trouble for practicing without a license.  Find Crusher in the tavern, and give him the password.\"",
  "speaker": "slink",
  "voiceId": 517,
  "file": "qfg1-3543-slink.mp3"
 }
]