diff --git a/dists/emscripten/custom_shell.html b/dists/emscripten/custom_shell.html
index 1d655a2a..5c2aa799 100644
--- a/dists/emscripten/custom_shell.html
+++ b/dists/emscripten/custom_shell.html
@@ -207,6 +207,46 @@
       }
     };
     Module.setStatus('Downloading ScummVM...');
+
+    // agitwo voice-over playback. The engine calls window.agitwoPlayVoice(target, hash)
+    // (via common/voiceover.cpp) for every displayed text; hash is the 64-bit FNV-1a
+    // of the whitespace-normalized string. Clips + manifests live under voices/<target>/.
+    (function () {
+      var manifests = {};   // target -> Map(hash -> clip file) | null (missing) | 'loading'
+      var currentAudio = null;
+      var currentHash = null;
+      function loadManifest(target) {
+        if (manifests[target] !== undefined) return;
+        manifests[target] = 'loading';
+        fetch('voices/' + target + '/manifest.json')
+          .then(function (r) { return r.ok ? r.json() : null; })
+          .then(function (json) {
+            manifests[target] = json ? new Map(Object.entries(json)) : null;
+            if (json) console.log('agitwo: loaded voice manifest for ' + target + ' (' + Object.keys(json).length + ' clips)');
+          })
+          .catch(function () { manifests[target] = null; });
+      }
+      window.agitwoPlayVoice = function (target, hash) {
+        var m = manifests[target];
+        if (m === undefined) { loadManifest(target); return false; }
+        if (m === 'loading' || m === null) return false;
+        var clip = m.get(hash);
+        if (!clip) return false;
+        if (currentHash === hash && currentAudio && !currentAudio.ended) return true; // don't restart same line
+        if (currentAudio) { currentAudio.pause(); currentAudio = null; }
+        currentAudio = new Audio('voices/' + target + '/' + clip);
+        currentHash = hash;
+        currentAudio.play().catch(function (e) { console.log('agitwo: voice play blocked/failed: ' + e); });
+        return true;
+      };
+      // Start manifest fetch early for the target passed in the URL hash, so the
+      // first lines of the game already have voices.
+      if (window.location.hash.length > 1) {
+        var args = decodeURI(window.location.hash.substring(1)).split(' ');
+        loadManifest(args[args.length - 1]);
+      }
+    })();
+
     window.onerror = function () {
