+
+#ifndef COMMON_VOICEOVER_H
+#define COMMON_VOICEOVER_H
+
+#include "common/str.h"
+
+namespace Common {
+
+/**
+ * agitwo voice-over bridge (Emscripten only).
+ *
+ * Looks up a pre-generated voice clip for the displayed text in the
+ * browser-side manifest (voices/<target>/manifest.json) and starts
+ * playback via the page's agitwoPlayVoice() JS function.
+ *
+ * The lookup key is the 64-bit FNV-1a hash of the text with all
+ * whitespace runs collapsed to single spaces and leading/trailing
+ * whitespace removed. The same normalization must be used by the
+ * manifest generator.
+ *
+ * @return true when a clip was found and playback started; the caller
+ *         should then skip text-to-speech for this string. Always
+ *         false on non-Emscripten builds.
+ */
+bool playVoiceOver(const String &text);
+
+} // namespace Common
+
+#endif
