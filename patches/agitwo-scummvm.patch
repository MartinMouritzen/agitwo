+
+#include "common/voiceover.h"
+
+#ifdef EMSCRIPTEN
+
+#include <emscripten.h>
+#include "common/config-manager.h"
+
+namespace Common {
+
+// Collapse whitespace runs to single spaces, trim ends. Must match the
+// normalization in tools/gen_voice_manifest.py on the agitwo side.
+static String normalizeForVoiceOver(const String &text) {
+	String out;
+	bool pendingSpace = false;
+	for (uint32 i = 0; i < text.size(); i++) {
+		const char c = text[i];
+		if (c == ' ' || c == '\n' || c == '\r' || c == '\t') {
+			pendingSpace = !out.empty();
+		} else {
+			if (pendingSpace) {
+				out += ' ';
+				pendingSpace = false;
+			}
+			out += c;
+		}
+	}
+	return out;
+}
+
+bool playVoiceOver(const String &text) {
+	const String normalized = normalizeForVoiceOver(text);
+	if (normalized.empty())
+		return false;
+
+	// 64-bit FNV-1a over the normalized bytes
+	uint64 hash = 0xcbf29ce484222325ULL;
+	for (uint32 i = 0; i < normalized.size(); i++) {
+		hash ^= (byte)normalized[i];
+		hash *= 0x100000001b3ULL;
+	}
+	const String hashStr = String::format("%016llx", (unsigned long long)hash);
+	const String target = ConfMan.getActiveDomainName();
+
+	const int played = EM_ASM_INT({
+		if (typeof window !== 'undefined' && window.agitwoPlayVoice)
+			return window.agitwoPlayVoice(UTF8ToString($0), UTF8ToString($1)) ? 1 : 0;
+		return 0;
+	}, target.c_str(), hashStr.c_str());
+	return played != 0;
+}
+
+} // namespace Common
+
+#endif
+// Non-EMSCRIPTEN (native) builds implement Common::playVoiceOver in
+// audio/agitwo_voiceover.cpp, which is allowed to depend on the mixer and
+// audio decoders (the common module is not).
