+
+// agitwo native voice-over playback.
+//
+// The EMSCRIPTEN build plays voice clips through the browser (see
+// common/voiceover.cpp). Native builds play them through ScummVM's own audio
+// mixer instead, so this implementation of Common::playVoiceOver lives in the
+// audio module (which may depend on the mixer and decoders; common may not).
+//
+// Voice data is expected next to the game files, in a subfolder:
+//     <game path>/agitwo-voices/manifest.json      (hash -> clip filename)
+//     <game path>/agitwo-voices/<clip>.mp3
+// The installer places it there. manifest.json maps the 64-bit FNV-1a hash of
+// the whitespace-normalized displayed text to a clip filename; the same
+// normalization and hash are used by the Emscripten path and by
+// tools/gen_voice_manifest.py, so a clip generated once works everywhere.
+
+#include "common/scummsys.h"
+
+#ifndef EMSCRIPTEN
+
+#include "common/config-manager.h"
+#include "common/file.h"
+#include "common/fs.h"
+#include "common/hashmap.h"
+#include "common/hash-str.h"
+#include "common/mutex.h"
+#include "common/str.h"
+#include "common/system.h"
+#include "common/textconsole.h"
+#include "common/formats/json.h"
+#include "common/voiceover.h"
+
+#include "audio/mixer.h"
+#ifdef USE_MAD
+#include "audio/audiostream.h"
+#include "audio/decoders/mp3.h"
+#endif
+
+namespace Common {
+
+// Collapse whitespace runs to single spaces, trim ends. Must match the
+// normalization in common/voiceover.cpp (Emscripten) and
+// tools/gen_voice_manifest.py.
+static String normalizeForVoiceOver(const String &text) {
+	String out;
+	bool pendingSpace = false;
+	for (uint32 i = 0; i < text.size(); i++) {
+		const char c = text[i];
+		if (c == ' ' || c == '\n' || c == '\r' || c == '\t') {
+			pendingSpace = !out.empty();
+		} else {
+			if (pendingSpace) {
+				out += ' ';
+				pendingSpace = false;
+			}
+			out += c;
+		}
+	}
+	return out;
+}
+
+static String voiceOverHash(const String &normalized) {
+	uint64 hash = 0xcbf29ce484222325ULL;
+	for (uint32 i = 0; i < normalized.size(); i++) {
+		hash ^= (byte)normalized[i];
+		hash *= 0x100000001b3ULL;
+	}
+	return String::format("%016llx", (unsigned long long)hash);
+}
+
+// Per-run cache: which target's manifest is loaded, the hash->file map, the
+// directory the clips live in, and the handle of whatever is currently
+// speaking so a new line interrupts the old one (mirrors the browser behavior).
+namespace {
+struct VoiceOverState {
+	bool triedLoad = false;
+	String loadedTarget;
+	FSNode voicesDir;
+	HashMap<String, String> map;      // hash -> clip filename
+	Audio::SoundHandle handle;
+	String lastHash;
+};
+VoiceOverState g_vo;
+Mutex g_voMutex;
+}
+
+// Locate <game path>/agitwo-voices and parse manifest.json into g_vo.map.
+// Returns false (with g_vo.triedLoad set) if voice data is not installed.
+static bool ensureManifestLoaded(const String &target) {
+	if (g_vo.triedLoad && g_vo.loadedTarget == target)
+		return !g_vo.map.empty();
+
+	g_vo.triedLoad = true;
+	g_vo.loadedTarget = target;
+	g_vo.map.clear();
+
+	if (!ConfMan.hasKey("path"))
+		return false;
+
+	FSNode gameDir(ConfMan.getPath("path"));
+	FSNode dir = gameDir.getChild("agitwo-voices");
+	if (!dir.isDirectory())
+		return false;
+	g_vo.voicesDir = dir;
+
+	FSNode manifestNode = dir.getChild("manifest.json");
+	Common::ScopedPtr<SeekableReadStream> stream(manifestNode.createReadStream());
+	if (!stream)
+		return false;
+
+	String jsonText;
+	{
+		const int64 size = stream->size();
+		if (size <= 0 || size > (16 << 20)) // sanity cap: 16 MB
+			return false;
+		char *buf = new char[size + 1];
+		const uint32 read = stream->read(buf, (uint32)size);
+		buf[read] = '\0';
+		jsonText = String(buf, read);
+		delete[] buf;
+	}
+
+	JSONValue *root = JSON::parse(jsonText);
+	if (!root) {
+		warning("agitwo: could not parse %s", manifestNode.getName().c_str());
+		return false;
+	}
+	if (root->isObject()) {
+		const JSONObject &obj = root->asObject();
+		for (JSONObject::const_iterator it = obj.begin(); it != obj.end(); ++it) {
+			if (it->_value && it->_value->isString())
+				g_vo.map[it->_key] = it->_value->asString();
+		}
+	}
+	delete root;
+
+	debug(1, "agitwo: loaded voice manifest for %s (%u clips)",
+	      target.c_str(), (uint)g_vo.map.size());
+	return !g_vo.map.empty();
+}
+
+bool playVoiceOver(const String &text) {
+	const String normalized = normalizeForVoiceOver(text);
+	if (normalized.empty())
+		return false;
+
+	StackLock lock(g_voMutex);
+
+	const String target = ConfMan.getActiveDomainName();
+	if (!ensureManifestLoaded(target))
+		return false;
+
+	const String hash = voiceOverHash(normalized);
+	if (!g_vo.map.contains(hash))
+		return false;
+
+	Audio::Mixer *mixer = g_system->getMixer();
+	if (!mixer)
+		return false;
+
+	// Don't restart a line that is already speaking.
+	if (g_vo.lastHash == hash && mixer->isSoundHandleActive(g_vo.handle))
+		return true;
+
+#ifdef USE_MAD
+	const String clip = g_vo.map[hash];
+	FSNode clipNode = g_vo.voicesDir.getChild(clip);
+	SeekableReadStream *clipStream = clipNode.createReadStream();
+	if (!clipStream)
+		return false;
+
+	Audio::SeekableAudioStream *audio = Audio::makeMP3Stream(clipStream, DisposeAfterUse::YES);
+	if (!audio)
+		return false;
+
+	if (mixer->isSoundHandleActive(g_vo.handle))
+		mixer->stopHandle(g_vo.handle);
+	mixer->playStream(Audio::Mixer::kSpeechSoundType, &g_vo.handle, audio);
+	g_vo.lastHash = hash;
+	return true;
+#else
+	// No MP3 decoder in this build: a matching clip exists but we cannot play
+	// it. Report not-played so the engine's own TTS/text handling proceeds.
+	return false;
+#endif
+}
+
+} // namespace Common
+
+#endif // !EMSCRIPTEN
